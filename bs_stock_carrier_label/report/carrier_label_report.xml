<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
    ============================================================
    QWeb-Template: Versandetiketten
    ============================================================
    Dieses Template rendert KEIN eigenes Layout — es nutzt
    postprocess_pdf_report (override in models) um das echte
    Carrier-PDF via pypdf einzuschleusen.

    Für den Nutzer sieht es aus wie jeder andere Report:
    - Erscheint unter Zahnrad → Drucken → "Versandetiketten"
    - IoT-Drucker wählbar (Einstellungen → Technisch → Reports)
    - Verhält sich identisch zu "Lieferschein"
    ============================================================
    -->
    <template id="report_carrier_label">
        <t t-call="web.html_container">
            <!--
                Minimales Placeholder-HTML.
                Der eigentliche PDF-Inhalt wird durch den
                postprocess_pdf_report-Override ersetzt.
            -->
            <t t-foreach="docs" t-as="picking">
                <div class="page">
                    <p style="font-family: Arial; font-size: 10px; color: #aaa;">
                        Versandetikett wird geladen...
                    </p>
                </div>
            </t>
        </t>
    </template>

    <!--
    ir.actions.report:
    - binding_type="report"  → erscheint unter "Drucken" (nicht "Aktion")
    - binding_model_id       → gebunden an stock.picking
    - binding_view_types     → nur im Formular
    -->
    <record id="action_report_carrier_label" model="ir.actions.report">
        <field name="name">Versandetiketten</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">bs_stock_carrier_label.report_carrier_label</field>
        <field name="report_file">bs_stock_carrier_label.report_carrier_label</field>
        <field name="print_report_name">
            'Versandetikett - %s' % (object.name or '')
        </field>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_type">report</field>
        <field name="binding_view_types">form</field>
        <field name="paperformat_id" ref="paperformat_carrier_label"/>
    </record>
</odoo>
