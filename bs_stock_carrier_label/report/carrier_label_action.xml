<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Papierformat: DHL-Standard A6 (105×148mm) -->
    <record id="paperformat_carrier_label" model="report.paperformat">
        <field name="name">Versandetikett DHL (A6 / 105x148mm)</field>
        <field name="default" eval="False"/>
        <field name="format">custom</field>
        <field name="page_width">105</field>
        <field name="page_height">148</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">0</field>
        <field name="margin_left">0</field>
        <field name="margin_right">0</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">150</field>
    </record>

    <!--
    Server-Action als zusätzlicher Einstiegspunkt im Zahnrad → Aktionen-Menü.
    Öffnet das zusammengeführte PDF direkt im Browser-Tab (act_url).
    Für IoT-Druck den ir.actions.report "Versandetiketten" nutzen.
    -->
    <record id="action_server_carrier_label" model="ir.actions.server">
        <field name="name">Versandetiketten (PDF-Download)</field>
        <field name="model_id" ref="stock.model_stock_picking"/>
        <field name="binding_model_id" ref="stock.model_stock_picking"/>
        <field name="binding_view_types">form</field>
        <field name="state">code</field>
        <field name="code">action = record.action_print_carrier_labels()</field>
    </record>
</odoo>
